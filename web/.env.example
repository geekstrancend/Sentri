# Database
DATABASE_URL="postgresql://user:password@localhost:5432/sentri_web"

# NextAuth Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="generate-a-random-string-with-openssl-rand-base64-32"

# GitHub OAuth
GITHUB_ID="your-github-oauth-app-id"
GITHUB_SECRET="your-github-oauth-app-secret"

# Google OAuth
GOOGLE_ID="your-google-oauth-id"
GOOGLE_SECRET="your-google-oauth-secret"

# Stripe Payment Gateway
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."

# Crypto Payment Gateway (Thirdweb or similar)
NEXT_PUBLIC_THIRDWEB_CLIENT_ID="your-thirdweb-client-id"

# Crypto payment verification (required for /api/payment/crypto to approve any payment)
ETHEREUM_RPC_URL="https://eth-mainnet.g.alchemy.com/v2/your-api-key"
PAYMENT_RECEIVER_ADDRESS="0xYourTreasuryWalletAddress"

# API Keys
ANTHROPIC_API_KEY="sk-ant-your-key"
